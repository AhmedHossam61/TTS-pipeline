# Stage 1 prompt expansion with Gemini API.
# Used only when generation.expand_with_gemini is true.
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Cloud / Vertex AI authentication for Gemini-TTS.
# Used by synthesis engine: name: gemini-tts.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# Use global for gemini-3.1-flash-tts-preview.
# For regional Vertex locations such as europe-west4, choose a model supported
# in that region, e.g. gemini-2.5-flash-tts.
GOOGLE_CLOUD_LOCATION=global

# Optional when using Application Default Credentials from gcloud.
# Required when authenticating with a service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json

# HuggingFace token (optional - only needed for gated models)
HF_TOKEN=your_hf_token_here
